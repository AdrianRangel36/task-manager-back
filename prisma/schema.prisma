// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// Enums
// ==========================================
enum TeamRole {
  OWNER    // El creador original del equipo
  ADMIN    // Puede administrar tareas y miembros
  MEMBER   // Participante regular
  PENDING   //Miembro que fue invitado,  debe 
}

// ==========================================
// Table 1: Users
// ==========================================
model User {
  id              Int      @id @default(autoincrement())
  name            String
  paternalSurname String
  maternalSurname String
  email           String   @unique
  password        String   
  
  // Audit
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  teamMemberships TeamMember[] 
}

// ==========================================
// Table 2: Team Members (Pivot Table)
// ==========================================
model TeamMember {
  id        Int      @id @default(autoincrement())
  userId    Int
  teamId    Int
  role      TeamRole @default(MEMBER)
  
  // Audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations 
  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  team           Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  assignedTasks  Task[]

  // Composite unique key
  @@unique([userId, teamId]) 
}

// ==========================================
// Table 3: Teams
// ==========================================
model Team {
  id        Int      @id @default(autoincrement())
  name      String
  
  // Audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  members TeamMember[] 
  tasks   Task[]       
}

// ==========================================
// Table 4: Tasks
// ==========================================
model Task {
  id               Int       @id @default(autoincrement())
  assignedMemberId Int       
  teamId           Int       
  status           String    // e.g., "TO_DO", "IN_PROGRESS", "DONE"
  name             String
  description      String
  goals            String
  startDate        DateTime
  endDate          DateTime
  
  // Audit
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  assignedMember TeamMember @relation(fields: [assignedMemberId], references: [id], onDelete: Cascade)
  team           Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
}